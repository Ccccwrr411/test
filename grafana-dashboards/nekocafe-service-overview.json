{
  "dashboard": {
    "uid": "nekocafe-service-overview",
    "title": "NekoCafé — 服务总览",
    "tags": ["nekocafe", "microservices"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "type": "stat",
        "title": "Reservation QPS",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
          }
        },
        "targets": [
          { "expr": "round(rate(http_server_duration_milliseconds_count{service=\"reservation\"}[1m]), 0.01)", "legendFormat": "QPS", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 2,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "type": "stat",
        "title": "Member QPS",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
          }
        },
        "targets": [
          { "expr": "round(rate(http_server_duration_milliseconds_count{service=\"member\"}[1m]), 0.01)", "legendFormat": "QPS", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 3,
        "gridPos": { "h": 10, "w": 8, "x": 0, "y": 8 },
        "type": "stat",
        "title": "Reservation P99 Latency",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] }
          }
        },
        "targets": [
          { "expr": "round(histogram_quantile(0.99, rate(http_server_duration_milliseconds_bucket{service=\"reservation\"}[5m])), 0.1)", "legendFormat": "P99", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 4,
        "gridPos": { "h": 10, "w": 8, "x": 8, "y": 8 },
        "type": "stat",
        "title": "Member P99 Latency",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] }
          }
        },
        "targets": [
          { "expr": "round(histogram_quantile(0.99, rate(http_server_duration_milliseconds_bucket{service=\"member\"}[5m])), 0.1)", "legendFormat": "P99", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 5,
        "gridPos": { "h": 10, "w": 8, "x": 16, "y": 8 },
        "type": "stat",
        "title": "Error Rate (5xx)",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
          }
        },
        "targets": [
          { "expr": "round(100 * sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[5m])) / sum(rate(http_server_duration_milliseconds_count[5m])), 0.01)", "legendFormat": "Error%", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 6,
        "gridPos": { "h": 12, "w": 12, "x": 0, "y": 18 },
        "type": "timeseries",
        "title": "QPS 趋势",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": { "unit": "reqps", "custom": { "lineInterpolation": "smooth", "fillOpacity": 15, "spanNulls": true } }
        },
        "targets": [
          { "expr": "round(rate(http_server_duration_milliseconds_count{service=\"reservation\"}[1m]), 0.01)", "legendFormat": "Reservation", "refId": "A" },
          { "expr": "round(rate(http_server_duration_milliseconds_count{service=\"member\"}[1m]), 0.01)", "legendFormat": "Member", "refId": "B" }
        ]
      },
      {
        "id": 7,
        "gridPos": { "h": 12, "w": 12, "x": 12, "y": 18 },
        "type": "timeseries",
        "title": "P50 / P95 / P99 延迟趋势 (Reservation)",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": { "unit": "ms", "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 } }
        },
        "targets": [
          { "expr": "round(histogram_quantile(0.50, rate(http_server_duration_milliseconds_bucket{service=\"reservation\"}[5m])), 0.1)", "legendFormat": "P50", "refId": "A" },
          { "expr": "round(histogram_quantile(0.95, rate(http_server_duration_milliseconds_bucket{service=\"reservation\"}[5m])), 0.1)", "legendFormat": "P95", "refId": "B" },
          { "expr": "round(histogram_quantile(0.99, rate(http_server_duration_milliseconds_bucket{service=\"reservation\"}[5m])), 0.1)", "legendFormat": "P99", "refId": "C" }
        ]
      },
      {
        "id": 8,
        "gridPos": { "h": 10, "w": 8, "x": 0, "y": 30 },
        "type": "stat",
        "title": "Reservation CPU Usage",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
          }
        },
        "targets": [
          { "expr": "round(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"reservation\"}[1m]) * 100, 0.1)", "legendFormat": "CPU%", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 9,
        "gridPos": { "h": 10, "w": 8, "x": 8, "y": 30 },
        "type": "stat",
        "title": "Reservation Memory Usage",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 268435456 }, { "color": "red", "value": 536870912 }] }
          }
        },
        "targets": [
          { "expr": "container_memory_usage_bytes{container_label_com_docker_compose_service=\"reservation\"}", "legendFormat": "Mem", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 10,
        "gridPos": { "h": 10, "w": 8, "x": 16, "y": 30 },
        "type": "stat",
        "title": "Open File Descriptors",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 900 }] }
          }
        },
        "targets": [
          { "expr": "process_open_fds{job=\"reservation\"}", "legendFormat": "FDs", "refId": "A" }
        ],
        "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "textMode": "value" }
      },
      {
        "id": 11,
        "gridPos": { "h": 10, "w": 12, "x": 0, "y": 40 },
        "type": "timeseries",
        "title": "错误率趋势 (5xx %)",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": { "unit": "percent", "min": 0, "custom": { "lineInterpolation": "smooth", "fillOpacity": 20 } },
          "overrides": [{ "matcher": { "id": "byName", "options": "1% 告警线" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }]
        },
        "targets": [
          { "expr": "round(100 * sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[1m])) / sum(rate(http_server_duration_milliseconds_count[1m])), 0.01)", "legendFormat": "Error Rate", "refId": "A" },
          { "expr": "1", "legendFormat": "1% 告警线", "refId": "B" }
        ]
      },
      {
        "id": 12,
        "gridPos": { "h": 10, "w": 12, "x": 12, "y": 40 },
        "type": "timeseries",
        "title": "CPU / Memory 资源使用趋势",
        "datasource": { "type": "prometheus", "uid": "nekocafe-prometheus" },
        "fieldConfig": {
          "defaults": { "custom": { "lineInterpolation": "smooth", "fillOpacity": 15 } },
          "overrides": [
            { "matcher": { "id": "byRegexp", "options": "/CPU/" }, "properties": [{ "id": "unit", "value": "percent" }] },
            { "matcher": { "id": "byRegexp", "options": "/Memory/" }, "properties": [{ "id": "unit", "value": "bytes" }] }
          ]
        },
        "targets": [
          { "expr": "round(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"reservation\"}[1m]) * 100, 0.1)", "legendFormat": "Reservation CPU%", "refId": "A" },
          { "expr": "container_memory_usage_bytes{container_label_com_docker_compose_service=\"reservation\"}", "legendFormat": "Reservation Memory", "refId": "B" }
        ]
      }
    ],
    "time": { "from": "now-1h", "to": "now" }
  }
}
